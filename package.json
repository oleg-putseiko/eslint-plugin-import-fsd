{
  "name": "eslint-plugin-import-fsd",
  "version": "3.0.0-canary.0",
  "description": "ESLint plugin for following FSD methodology in imports and file locations",
  "license": "MIT",
  "author": "Oleg Putseiko <oleg.putseiko@gmail.com> (https://github.com/oleg-putseiko)",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "import",
    "fsd",
    "feature-sliced",
    "architecture"
  ],
  "homepage": "https://github.com/oleg-putseiko/eslint-plugin-import-fsd",
  "repository": {
    "type": "git",
    "url": "https://github.com/oleg-putseiko/eslint-plugin-import-fsd"
  },
  "bugs": {
    "url": "https://github.com/oleg-putseiko/eslint-plugin-import-fsd/issues"
  },
  "main": "dist/index.js",
  "files": [
    "dist/**/*"
  ],
  "exports": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier -c .",
    "format:fix": "prettier -w .",
    "lint": "eslint ./src/**/*.{js,ts,json} && yarn format",
    "lint:fix": "eslint ./src/**/*.{js,ts,json} --fix && yarn format:fix",
    "lint:strict": "eslint ./src/**/*.{js,ts,json} --max-warnings=0 && yarn format",
    "prepare": "husky install | chmod +x ./.husky/*",
    "test": "jest",
    "typecheck": "tsc --noEmit --incremental false"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0 <10.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.30",
    "@types/eslint": "^9.6.1",
    "@types/jest": "^29.5.11",
    "@types/node": "^24.12.2",
    "@typescript-eslint/rule-tester": "^8.59.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": "^20.9.0 || >=21.1.0 <25.0.0"
  },
  "volta": {
    "node": "24.14.1",
    "yarn": "4.13.0"
  }
}
