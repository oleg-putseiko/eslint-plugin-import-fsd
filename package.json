{
  "name": "eslint-plugin-import-fsd",
  "version": "3.0.0",
  "description": "A smart ESLint plugin that helps you enforce and maintain Feature-Sliced Design (FSD) architecture.",
  "license": "MIT",
  "author": "Oleg Putseiko <oleg.putseiko@gmail.com> (https://github.com/oleg-putseiko)",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "import",
    "fsd",
    "feature-sliced",
    "feature-sliced-design",
    "architecture",
    "boundaries",
    "layers",
    "hierarchy",
    "infrastructure",
    "lint"
  ],
  "homepage": "https://github.com/oleg-putseiko/eslint-plugin-import-fsd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oleg-putseiko/eslint-plugin-import-fsd.git"
  },
  "bugs": {
    "url": "https://github.com/oleg-putseiko/eslint-plugin-import-fsd/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/**/*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run build:js && npm run build:ts",
    "build:js": "swc src -d dist --strip-leading-paths --ignore \"node_modules,**/*.test.ts,**/*.d.ts\"",
    "build:ts": "tsc --emitDeclarationOnly && mkdir -p dist && find src -name \"*.d.ts\" -exec cp {} dist/ \\;",
    "lint": "eslint ./src -c ./eslint.config.mjs",
    "lint:fix": "yarn lint --fix && yarn format:fix",
    "lint:strict": "yarn lint --max-warnings=0 && yarn format",
    "format": "prettier -c .",
    "format:fix": "prettier -w .",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "jest",
    "setup": "yarn install && yarn setup:husky",
    "setup:husky": "husky && chmod +x ./.husky/*",
    "deps:audit": "bash ./scripts/deps/audit.sh",
    "scripts:perms": "find ./scripts -type f -name \"*.sh\" -exec chmod +x {} +",
    "scripts:perms:track": "find ./scripts -type f -name \"*.sh\" -exec git update-index --chmod=+x {} +"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0 <10.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.30",
    "@types/eslint": "^9.6.1",
    "@types/jest": "^29.5.11",
    "@types/node": "^24.12.2",
    "@typescript-eslint/rule-tester": "^8.59.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-sh": "^0.18.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": "^20.9.0 || >=21.1.0 <25.0.0"
  },
  "volta": {
    "node": "24.14.1",
    "yarn": "4.13.0"
  }
}
